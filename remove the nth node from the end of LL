class Solution {
public:
    ListNode* removeNthFromEnd(ListNode* head, int n) {
        ListNode* temp=head;
        int count=0;
        while(temp!=nullptr){
            count++;
            temp=temp->next;
        }
         if(count==n){
            return head->next;
        }
        temp=head;
        int nth=count-n;
        for(int i=1;i<nth;i++){
            temp=temp->next;
        }
       
        temp->next=temp->next->next;
        return head;
    }
};
