#include <iostream>
using namespace std;

int binaryToDecimal(int n)
{
    int num=n;
    int temp=num;
    int base=1;
    int dec_val=0;
    while(temp){
        int last_dig=temp%10;
        temp=temp/10;
        dec_val=dec_val+last_dig*base;
        base=base*2;
    }
    return dec_val;
}

int main()
{
    int num = 100001;
    cout << binaryToDecimal(num) << endl;
}
